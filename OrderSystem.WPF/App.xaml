<Application
    x:Class="OrderSystem.WPF.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:classes="clr-namespace:OrderSystem.WPF.Classes"
    xmlns:conv="clr-namespace:OrderSystem.WPF.Converters"
    xmlns:local="clr-namespace:OrderSystem.WPF"
    xmlns:navigation="clr-namespace:OrderSystem.WPF.Navigation"
    xmlns:views="clr-namespace:OrderSystem.WPF.Views"
    xmlns:vm="clr-namespace:OrderSystem.WPF.ViewModels">
    <Application.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

        <Style TargetType="{x:Type ContentPresenter}">
            <Setter Property="navigation:ViewTrackingBehavior.Enable" Value="True" />
        </Style>

        <Style x:Key="BaseControlStyle" TargetType="{x:Type Control}">
            <Setter Property="Margin" Value="5" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style
            x:Key="ValidationStyleBase"
            BasedOn="{StaticResource BaseControlStyle}"
            TargetType="{x:Type Control}">
            <Style.Triggers>

                <DataTrigger Binding="{Binding (behaviors:ValidationHelper.ValidationState).Level, RelativeSource={RelativeSource Self}}" Value="Error">
                    <Setter Property="BorderBrush" Value="Red" />
                </DataTrigger>

                <DataTrigger Binding="{Binding (behaviors:ValidationHelper.ValidationState).Level, RelativeSource={RelativeSource Self}}" Value="Warning">
                    <Setter Property="BorderBrush" Value="DarkOrange" />
                </DataTrigger>

            </Style.Triggers>
        </Style>

        <Style BasedOn="{StaticResource BaseControlStyle}" TargetType="{x:Type TabControl}" />
        <Style BasedOn="{StaticResource BaseControlStyle}" TargetType="{x:Type Button}">
            <Setter Property="classes:CommandExtensions.CommitBeforeExecute" Value="True" />
        </Style>
        <Style BasedOn="{StaticResource ValidationStyleBase}" TargetType="{x:Type TextBox}" />
        <Style BasedOn="{StaticResource ValidationStyleBase}" TargetType="{x:Type DatePicker}" />
        <Style BasedOn="{StaticResource BaseControlStyle}" TargetType="{x:Type Label}" />
        <Style BasedOn="{StaticResource ValidationStyleBase}" TargetType="{x:Type ComboBox}" />
        <Style BasedOn="{StaticResource BaseControlStyle}" TargetType="{x:Type ListView}">
            <Setter Property="behaviors:ListViewDoubleClickBehavior.Command" Value="{Binding EditCommand}" />
        </Style>

        <Style x:Key="ValidationTextLabel" TargetType="{x:Type Label}">
            <Setter Property="Margin" Value="0,-10,0,0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Content" Value="{Binding (behaviors:ValidationHelper.ValidationState).Message, RelativeSource={RelativeSource Self}}" />
            <Style.Triggers>

                <DataTrigger Binding="{Binding (behaviors:ValidationHelper.ValidationState).Level, RelativeSource={RelativeSource Self}}" Value="Error">
                    <Setter Property="Foreground" Value="Red" />
                </DataTrigger>

                <DataTrigger Binding="{Binding (behaviors:ValidationHelper.ValidationState).Level, RelativeSource={RelativeSource Self}}" Value="Warning">
                    <Setter Property="Foreground" Value="DarkOrange" />
                </DataTrigger>

            </Style.Triggers>
        </Style>

        <Style
            x:Key="ErrorTextLabel"
            BasedOn="{StaticResource ValidationTextLabel}"
            TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="Red" />
        </Style>

        <Style
            x:Key="WarningTextLabel"
            BasedOn="{StaticResource ValidationTextLabel}"
            TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="DarkOrange" />
        </Style>

        <DataTemplate DataType="{x:Type vm:MainViewModel}">
            <views:MainView />
        </DataTemplate>
    </Application.Resources>
</Application>
