<ResourceDictionary
    x:Class="OrderSystem.WPF.ResourceDictionaries.ProductsDictionary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OrderSystem.WPF.Views.Products"
    xmlns:vm="clr-namespace:OrderSystem.WPF.ViewModels.Products">
    <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
        <views:ProductsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ProductViewModel}">
        <views:ProductView />
    </DataTemplate>
</ResourceDictionary>