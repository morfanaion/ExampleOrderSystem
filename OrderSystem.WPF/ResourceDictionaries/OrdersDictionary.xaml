<ResourceDictionary
    x:Class="OrderSystem.WPF.ResourceDictionaries.OrdersDictionary"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:OrderSystem.WPF.Views.Orders"
    xmlns:vm="clr-namespace:OrderSystem.WPF.ViewModels.Orders">
    <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
        <views:OrdersView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:OrderViewModel}">
        <views:OrderView />
    </DataTemplate>
</ResourceDictionary>