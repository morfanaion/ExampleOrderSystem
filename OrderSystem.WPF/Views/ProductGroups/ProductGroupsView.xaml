<UserControl
    x:Class="OrderSystem.WPF.Views.ProductGroups.ProductGroupsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderSystem.WPF.Views.ProductGroups"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:OrderSystem.Data.Resources;assembly=OrderSystem.Data"
    xmlns:wresx="clr-namespace:OrderSystem.Business.Resources;assembly=OrderSystem.Business"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ListView
            x:Name="ProductsGroupsListView"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="4"
            ItemsSource="{Binding ProductGroupsSource}">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding Id}" Header="{x:Static resx:OrderResources.Id}" />
                    <GridViewColumn DisplayMemberBinding="{Binding Name}" Header="{x:Static resx:OrderResources.Name}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button
            Grid.Row="1"
            Grid.Column="1"
            Command="{Binding AddCommand}"
            Content="{x:Static wresx:OrderBusinessResources.Add}" />
        <Button
            Grid.Row="1"
            Grid.Column="2"
            Command="{Binding EditCommand}"
            CommandParameter="{Binding SelectedItem, ElementName=ProductsGroupsListView}"
            Content="{x:Static wresx:OrderBusinessResources.Edit}" />
        <Button
            Grid.Row="1"
            Grid.Column="3"
            Command="{Binding DeleteCommand}"
            CommandParameter="{Binding SelectedItem, ElementName=ProductsGroupsListView}"
            Content="{x:Static wresx:OrderBusinessResources.Delete}" />
    </Grid>
</UserControl>
