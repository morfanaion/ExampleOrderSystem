<UserControl
    x:Class="OrderSystem.WPF.Views.ProductGroups.ProductGroupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderSystem.WPF.Views.ProductGroups"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="clr-namespace:OrderSystem.WPF.Navigation"
    xmlns:resx="clr-namespace:OrderSystem.Data.Resources;assembly=OrderSystem.Data"
    xmlns:wresx="clr-namespace:OrderSystem.WPF.Resources"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <nav:WindowSettings.Settings>
        <nav:WindowSettings
            Width="345"
            Height="170"
            ResizeMode="NoResize" />
    </nav:WindowSettings.Settings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.Id}" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Id]}"
            Text="{Binding CurrentObject.Id}" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Id]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Label
            Grid.Row="2"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.Name}" />
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Name]}"
            Text="{Binding CurrentObject.Name}" />
        <Label
            Grid.Row="3"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Name]}"
            Style="{StaticResource ValidationTextLabel}" />

        <Grid
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding OkCommand}"
                Content="{x:Static wresx:WpfOrderResources.Save}"
                IsDefault="True" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding CancelCommand}"
                Content="{x:Static wresx:WpfOrderResources.Cancel}"
                IsCancel="True" />
        </Grid>
    </Grid>
</UserControl>
