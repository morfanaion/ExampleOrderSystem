<UserControl
    x:Class="OrderSystem.WPF.Views.Orders.OrderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:conv="clr-namespace:OrderSystem.WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderSystem.WPF.Views.Orders"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="clr-namespace:OrderSystem.WPF.Navigation"
    xmlns:resx="clr-namespace:OrderSystem.Data.Resources;assembly=OrderSystem.Data"
    xmlns:wresx="clr-namespace:OrderSystem.Business.Resources;assembly=OrderSystem.Business"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PriceInCentsToStringConverter x:Key="convPriceInCentsToString" IncludeCurrencySign="True" />
    </UserControl.Resources>
    <nav:WindowSettings.Settings>
        <nav:WindowSettings
            Width="435"
            Height="540"
            ResizeMode="NoResize" />
    </nav:WindowSettings.Settings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.PlacedAt}" />
        <DatePicker
            Grid.Row="0"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[PlacedAt]}"
            SelectedDate="{Binding CurrentObject.PlacedAt}" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[PlacedAt]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Label
            Grid.Row="2"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.TotalPrice}" />
        <Label
            Grid.Row="2"
            Grid.Column="1"
            Content="{Binding CurrentObject.TotalPriceInCents, Converter={StaticResource convPriceInCentsToString}}" />
        <Label
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Content="{x:Static resx:OrderResources.OrderLines}"
            FontWeight="Bold" />
        <ContentControl
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Content="{Binding OrderLinesViewModel}" />
        <Label
            Grid.Row="5"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[OrderLines]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Grid
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding OkCommand}"
                Content="{x:Static wresx:OrderBusinessResources.Save}"
                IsDefault="True" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding CancelCommand}"
                Content="{x:Static wresx:OrderBusinessResources.Cancel}"
                IsCancel="True" />
        </Grid>
    </Grid>
</UserControl>
