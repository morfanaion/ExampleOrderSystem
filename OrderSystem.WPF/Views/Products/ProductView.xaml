<UserControl
    x:Class="OrderSystem.WPF.Views.Products.ProductView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:classes="clr-namespace:OrderSystem.WPF.Classes"
    xmlns:conv="clr-namespace:OrderSystem.WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderSystem.WPF.Views.Products"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="clr-namespace:OrderSystem.WPF.Navigation"
    xmlns:resx="clr-namespace:OrderSystem.Data.Resources;assembly=OrderSystem.Data"
    xmlns:wresx="clr-namespace:OrderSystem.Business.Resources;assembly=OrderSystem.Business"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <nav:WindowSettings.Settings>
        <nav:WindowSettings
            Width="345"
            Height="220"
            ResizeMode="NoResize" />
    </nav:WindowSettings.Settings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.Name}" />
        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Name]}"
            Text="{Binding CurrentObject.Name}" />
        <Label
            Grid.Row="1"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[Name]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Label
            Grid.Row="2"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.ProductGroup}" />
        <ComboBox
            Grid.Row="2"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[ProductGroup]}"
            DisplayMemberPath="Name"
            ItemsSource="{Binding ProductGroupsLookup}"
            SelectedValue="{Binding CurrentObject.ProductGroup}" />
        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Margin="11,8,0,0"
            Foreground="Gray"
            IsHitTestVisible="False"
            Text="{x:Static wresx:OrderBusinessResources.ChooseProductgroup}"
            Visibility="{Binding CurrentObject.ProductGroup, Converter={StaticResource NullToVisibilityConverter}}" />
        <Label
            Grid.Row="3"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[ProductGroup]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Label
            Grid.Row="4"
            Grid.Column="0"
            Content="{x:Static resx:OrderResources.Price}" />
        <TextBox
            Grid.Row="4"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[PriceInCents]}"
            Text="{classes:EmptyCurrencyBinding CurrentObject.PriceInCents}" />
        <Label
            Grid.Row="5"
            Grid.Column="1"
            behaviors:ValidationHelper.ValidationState="{Binding Validation[PriceInCents]}"
            Style="{StaticResource ValidationTextLabel}" />
        <Grid
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding OkCommand}"
                Content="{x:Static wresx:OrderBusinessResources.Save}"
                IsDefault="True" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding CancelCommand}"
                Content="{x:Static wresx:OrderBusinessResources.Cancel}"
                IsCancel="True" />
        </Grid>
    </Grid>
</UserControl>
