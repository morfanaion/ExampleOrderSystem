<UserControl
    x:Class="OrderSystem.WPF.Views.Products.ProductsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:OrderSystem.WPF.Behaviors"
    xmlns:controls="clr-namespace:OrderSystem.WPF.Controls"
    xmlns:conv="clr-namespace:OrderSystem.WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OrderSystem.WPF.Views.Products"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:OrderSystem.Data.Resources;assembly=OrderSystem.Data"
    xmlns:wresx="clr-namespace:OrderSystem.Business.Resources;assembly=OrderSystem.Business"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:PriceInCentsToStringConverter x:Key="convPriceInCentsToString" IncludeCurrencySign="True" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="4"
            Orientation="Horizontal">
            <Button Command="{Binding ClearFilterCommand}" Content="{x:Static wresx:OrderBusinessResources.ClearFilter}" />
            <Label Content="{x:Static resx:OrderResources.ProductGroup}" />
            <controls:SearchComboBox
                Width="150"
                DisplayMemberPath="Name"
                ItemsSource="{Binding ProductGroupsFilterLookup}"
                SearchProvider="{Binding ProductGroupsFilterSearchProvider}"
                SelectedItem="{Binding SelectedFilterProductGroup}" />
            <Label Content="{x:Static resx:OrderResources.ProductName}" />
            <TextBox Width="150" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <ListView
            x:Name="ProductsListView"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="4"
            ItemsSource="{Binding ProductsSource}"
            SelectedItem="{Binding SelectedItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding Id}" Header="{x:Static resx:OrderResources.Id}" />
                    <GridViewColumn DisplayMemberBinding="{Binding Name}" Header="{x:Static resx:OrderResources.Name}" />
                    <GridViewColumn DisplayMemberBinding="{Binding ProductGroup.Name}" Header="{x:Static resx:OrderResources.ProductGroup}" />
                    <GridViewColumn Width="Auto" Header="{x:Static resx:OrderResources.Price}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Text="{Binding PriceInCents, Converter={StaticResource convPriceInCentsToString}}"
                                    TextAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <Button
            Grid.Row="2"
            Grid.Column="1"
            Command="{Binding AddCommand}"
            Content="{x:Static wresx:OrderBusinessResources.Add}" />
        <Button
            Grid.Row="2"
            Grid.Column="2"
            Command="{Binding EditCommand}"
            CommandParameter="{Binding SelectedItem, ElementName=ProductsListView}"
            Content="{x:Static wresx:OrderBusinessResources.Edit}" />
        <Button
            Grid.Row="2"
            Grid.Column="3"
            Command="{Binding DeleteCommand}"
            CommandParameter="{Binding SelectedItem, ElementName=ProductsListView}"
            Content="{x:Static wresx:OrderBusinessResources.Delete}" />
    </Grid>
</UserControl>
